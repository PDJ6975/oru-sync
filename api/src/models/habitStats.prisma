model HabitStats {
    id Int @id @default(autoincrement())
    year Int
    currentStreak Int
    bestStreak Int
    totalCompletions Int
    totalAccumulation Float 
    recordedDays Int
    habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
    habitId String
    @@unique([habitId, year])
}