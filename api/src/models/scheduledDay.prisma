model ScheduledDay {
    id Int @id @default(autoincrement())
    day WeekDay
    habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
    habitId Int

    @@unique([habitId, day]) // un hábito no puede tener el mismo día programado más de una vez
}
enum WeekDay {
    MONDAY
    TUESDAY
    WEDNESDAY
    THURSDAY
    FRIDAY
    SATURDAY
    SUNDAY
}
